local gui = Instance.new("ScreenGui")
gui.Name = "XYTEEY_HUB_V3"
gui.Parent = player.PlayerGui
gui.ResetOnSpawn = false

local function abrirPainel()
    local main = Instance.new("Frame", gui)
    main.Name = "MainFrame"
    main.Size = UDim2.new(0, 520, 0, 400)
    main.Position = UDim2.new(0.5, -260, 0.5, -200)
    main.BackgroundColor3 = BgColor
    main.ClipsDescendants = true
    ApplyCorner(main, 12)
    
    local stroke = Instance.new("UIStroke", main)
    stroke.Thickness = 2.5
    RGB(stroke, "Color")

    -- Sidebar
    local sidebar = Instance.new("Frame", main)
    sidebar.Size = UDim2.new(0, 150, 1, 0)
    sidebar.BackgroundColor3 = SecondaryColor
    ApplyCorner(sidebar, 12)

    local sideTitle = Instance.new("TextLabel", sidebar)
    sideTitle.Size = UDim2.new(1, 0, 0, 70); sideTitle.Text = "XYTEEY"; sideTitle.Font = Enum.Font.GothamBlack; sideTitle.TextColor3 = Color3.new(1,1,1); sideTitle.TextSize = 22; sideTitle.BackgroundTransparency = 1

    local btnContainer = Instance.new("Frame", sidebar)
    btnContainer.Size = UDim2.new(1, 0, 1, -70); btnContainer.Position = UDim2.new(0, 0, 0, 70); btnContainer.BackgroundTransparency = 1
    local blayout = Instance.new("UIListLayout", btnContainer); blayout.Padding = UDim.new(0, 10); blayout.HorizontalAlignment = "Center"

    -- Conteúdo
    local content = Instance.new("Frame", main)
    content.Size = UDim2.new(1, -170, 1, -40); content.Position = UDim2.new(0, 160, 0, 20); content.BackgroundTransparency = 1

    local pageTeleports = Instance.new("ScrollingFrame", content)
    pageTeleports.Size = UDim2.new(1, 0, 1, 0); pageTeleports.BackgroundTransparency = 1; pageTeleports.ScrollBarThickness = 0; pageTeleports.Visible = true

    local pageScripts = Instance.new("ScrollingFrame", content)
    pageScripts.Size = UDim2.new(1, 0, 1, 0); pageScripts.BackgroundTransparency = 1; pageScripts.ScrollBarThickness = 0; pageScripts.Visible = false

    local teleLayout = Instance.new("UIListLayout", pageTeleports); teleLayout.Padding = UDim.new(0, 6)
    local scriptLayout = Instance.new("UIListLayout", pageScripts); scriptLayout.Padding = UDim.new(0, 6)

    local function createTab(name, page)
        local b = Instance.new("TextButton", btnContainer)
        b.Size = UDim2.new(0.85, 0, 0, 45); b.Text = name; b.Font = Enum.Font.GothamBold; b.TextColor3 = Color3.new(0.6, 0.6, 0.6); b.BackgroundColor3 = Color3.fromRGB(35, 35, 35); ApplyCorner(b, 8)
        
        b.MouseButton1Click:Connect(function()
            pageTeleports.Visible = (page == "tele")
            pageScripts.Visible = (page == "scripts")
            for _, v in pairs(btnContainer:GetChildren()) do
                if v:IsA("TextButton") then 
                    TweenService:Create(v, TweenInfo.new(0.3), {TextColor3 = Color3.new(0.6,0.6,0.6), BackgroundColor3 = Color3.fromRGB(35,35,35)}):Play()
                end
            end
            TweenService:Create(b, TweenInfo.new(0.3), {TextColor3 = Color3.new(1,1,1), BackgroundColor3 = AccentColor}):Play()
        end)
    end

    createTab("Teleports", "tele")
    createTab("Scripts", "scripts")

    -- Teleports
    for _, dest in pairs(DESTINOS) do
        local b = Instance.new("TextButton", pageTeleports)
        b.Size = UDim2.new(0.98, 0, 0, 40); b.Text = "  " .. dest.nome; b.BackgroundColor3 = SecondaryColor; b.TextColor3 = Color3.new(0.8, 0.8, 0.8); b.Font = Enum.Font.GothamSemibold; b.TextXAlignment = "Left"; ApplyCorner(b, 6)
        b.MouseButton1Click:Connect(function()
            if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                player.Character.HumanoidRootPart.CFrame = CFrame.new(dest.pos)
            end
        end)
    end

    -- Scripts area
    local function createScriptBtn(name, url)
        local b = Instance.new("TextButton", pageScripts)
        b.Size = UDim2.new(0.98, 0, 0, 48); b.Text = name; b.BackgroundColor3 = SecondaryColor; b.TextColor3 = AccentColor; b.Font = Enum.Font.GothamBold; ApplyCorner(b, 8)
        b.MouseButton1Click:Connect(function() loadstring(game:HttpGet(url, true))() end)
    end

    local function createEspExpander()
        local frame = Instance.new("Frame", pageScripts)
        frame.Size = UDim2.new(0.98, 0, 0, 48); frame.BackgroundColor3 = SecondaryColor; frame.ClipsDescendants = true; ApplyCorner(frame, 8)
        local btn = Instance.new("TextButton", frame); btn.Size = UDim2.new(1, 0, 0, 48); btn.Text = "  ESP System"; btn.Font = Enum.Font.GothamBold; btn.TextColor3 = Color3.new(1,1,1); btn.TextXAlignment = "Left"; btn.BackgroundTransparency = 1
        local arrow = Instance.new("TextLabel", btn); arrow.Size = UDim2.new(0, 48, 1, 0); arrow.Position = UDim2.new(1, -48, 0, 0); arrow.Text = "▼"; arrow.TextColor3 = AccentColor; arrow.BackgroundTransparency = 1
        
        local opt = Instance.new("Frame", frame); opt.Size = UDim2.new(1,0,0,90); opt.Position = UDim2.new(0,0,0,48); opt.BackgroundTransparency = 1
        local on = Instance.new("TextButton", opt); on.Size = UDim2.new(0.9,0,0,35); on.Position = UDim2.new(0.05,0,0,5); on.Text = "ATIVAR ESP"; on.BackgroundColor3 = Color3.fromRGB(0, 180, 80); on.TextColor3 = Color3.new(1,1,1); ApplyCorner(on)
        local off = Instance.new("TextButton", opt); off.Size = UDim2.new(0.9,0,0,35); off.Position = UDim2.new(0.05,0,0,45); off.Text = "DESATIVAR ESP"; off.BackgroundColor3 = Color3.fromRGB(180, 0, 0); off.TextColor3 = Color3.new(1,1,1); ApplyCorner(off)

        local open = false
        btn.MouseButton1Click:Connect(function()
            open = not open
            TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Quart), {Size = open and UDim2.new(0.98, 0, 0, 140) or UDim2.new(0.98, 0, 0, 48)}):Play()
            TweenService:Create(arrow, TweenInfo.new(0.3), {Rotation = open and 180 or 0}):Play()
        end)
        on.MouseButton1Click:Connect(function() loadstring(game:HttpGet("https://raw.githubusercontent.com/wa0101/Roblox-ESP/refs/heads/main/esp.lua", true))() end)
    end

    createEspExpander()
    createScriptBtn("Aimbot do Allan", "https://raw.githubusercontent.com/ttwizz/Open-Aimbot/master/source.lua")
    createScriptBtn("Nameless Admin", "https://raw.githubusercontent.com/ltseverydayyou/Nameless-Admin/main/Source.lua")

    task.spawn(function()
        while task.wait(0.5) do
            pageTeleports.CanvasSize = UDim2.new(0,0,0, teleLayout.AbsoluteContentSize.Y + 10)
            pageScripts.CanvasSize = UDim2.new(0,0,0, scriptLayout.AbsoluteContentSize.Y + 10)
        end
    end)

    -- Arrastar, Toggle, Pânico e Fantasma
    UIS.InputBegan:Connect(function(i, g) 
        if not g and i.KeyCode == ToggleKey then main.Visible = not main.Visible end 
        if i.KeyCode == PanicKey then gui:Destroy() end -- Tecla J: Deleta tudo
        
        if i.KeyCode == GhostKey and not g then -- Tecla P: Modo Fantasma
            local targetTrans = (main.BackgroundTransparency > 0.1 and 0 or 0.98)
            local textTrans = (targetTrans > 0.5 and 0.95 or 0)
            TweenService:Create(main, TweenInfo.new(0.5), {BackgroundTransparency = targetTrans}):Play()
            for _, v in pairs(main:GetDescendants()) do
                if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
                    TweenService:Create(v, TweenInfo.new(0.5), {TextTransparency = textTrans, BackgroundTransparency = (targetTrans == 0 and v.BackgroundTransparency or 0.98)}):Play()
                end
                if v:IsA("UIStroke") then TweenService:Create(v, TweenInfo.new(0.5), {Transparency = textTrans}):Play() end
            end
        end
    end)
    
    local d,s,sp;sidebar.InputBegan:Connect(function(i)if i.UserInputType==Enum.UserInputType.MouseButton1 then d=true;s=i.Position;sp=main.Position end end)
    UIS.InputChanged:Connect(function(i)if d and i.UserInputType==Enum.UserInputType.MouseMovement then local delta=i.Position-s;main.Position=UDim2.new(sp.X.Scale,sp.X.Offset+delta.X,sp.Y.Scale,sp.Y.Offset+delta.Y)end end)
    UIS.InputEnded:Connect(function(i)if i.UserInputType==Enum.UserInputType.MouseButton1 then d=false end end)
end

