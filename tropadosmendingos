    local shadow = Instance.new("TextLabel", welcome); shadow.Size = UDim2.new(1,0,1,0); shadow.Position = UDim2.new(0,2,0,2); shadow.Text = "BEM VINDO BUT"; shadow.Font = Enum.Font.GothamBlack; shadow.TextSize = 28; shadow.TextColor3 = Color3.new(0,0,0); shadow.ZIndex = 0; shadow.BackgroundTransparency = 1

    local box = Instance.new("TextBox", lf); box.Size = UDim2.new(0.85, 0, 0, 50); box.Position = UDim2.new(0.075, 0, 0.4, 0); box.PlaceholderText = "digite a key doidao"; box.Text = ""; box.BackgroundColor3 = Color3.fromRGB(20,20,20); box.TextColor3 = AccentColor; box.Font = Enum.Font.GothamSemibold; box.TextSize = 16; ApplyCorner(box, 10)
    local bs = Instance.new("UIStroke", box); bs.Thickness = 1; bs.Color = Color3.fromRGB(50,50,50)

    local btn = Instance.new("TextButton", lf); btn.Size = UDim2.new(0.85, 0, 0, 50); btn.Position = UDim2.new(0.075, 0, 0.68, 0); btn.Text = "VERIFICAR AGORA"; btn.Font = Enum.Font.GothamBlack; btn.TextSize = 14; btn.TextColor3 = Color3.fromRGB(15,15,15); btn.BackgroundColor3 = AccentColor; ApplyCorner(btn, 10)

    btn.MouseEnter:Connect(function() TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.new(1,1,1)}):Play() end)
    btn.MouseLeave:Connect(function() TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = AccentColor}):Play() end)

    btn.MouseButton1Click:Connect(function()
        if box.Text == KEY_CORRETA then
            TweenService:Create(ls, TweenInfo.new(0.5), {Thickness = 10, Transparency = 1}):Play()
            local t = TweenService:Create(lf, TweenInfo.new(0.7, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Position = UDim2.new(0.5, -175, 1.2, 0)})
            t:Play()
            t.Completed:Connect(function() lf:Destroy(); abrirPainel() end)
        else
            local originalPos = lf.Position
            for i = 1, 6 do
                lf.Position = originalPos + UDim2.new(0, math.random(-5, 5), 0, 0)
                task.wait(0.05)
            end
            lf.Position = originalPos
            box.Text = ""; box.PlaceholderText = "ERROU, SEU MENDINGO!"; box.PlaceholderColor3 = Color3.fromRGB(255, 50, 50)
            task.wait(1.5); box.PlaceholderText = "digite a key doidao"; box.PlaceholderColor3 = Color3.fromRGB(150, 150, 150)
        end
    end)
end

Iniciar()
