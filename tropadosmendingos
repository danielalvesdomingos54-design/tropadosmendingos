-------------------------------------------------
-- UTILS
-------------------------------------------------

local function ApplyCorner(obj, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 10)
    c.Parent = obj
end

local function RGB(obj, prop)
    task.spawn(function()
        local h = 0
        while obj and obj.Parent do
            h = h + 0.002
            obj[prop] = Color3.fromHSV(h, 0.6, 1)
            task.wait()
        end
    end)
end

