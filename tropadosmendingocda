-------------------------------------------------
-- UTILS
-------------------------------------------------

local function ApplyCorner(obj, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = obj
end

local function MakeShadow(obj)
    local s = Instance.new("UIStroke")
    s.Thickness = 1.5
    s.Transparency = 0.5
    s.Color = Color3.new(1,1,1)
    s.Parent = obj
    return s
end

local function RGB(obj, prop)
    task.spawn(function()
        local h = 0
        while obj and obj.Parent do
            h = h + 0.003
            obj[prop] = Color3.fromHSV(h, 0.7, 1)
            task.wait()
        end
    end)
end

