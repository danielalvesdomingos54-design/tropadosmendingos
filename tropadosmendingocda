    local box = Instance.new("TextBox", lf); box.Size = UDim2.new(0.85, 0, 0, 45); box.Position = UDim2.new(0.075, 0, 0.35, 0); box.PlaceholderText = "Digite a key doidao"; box.Text = ""; box.BackgroundColor3 = SecondaryColor; box.TextColor3 = Color3.new(1,1,1); box.Font = Enum.Font.GothamSemibold; ApplyCorner(box, 8)
    
    local btn = Instance.new("TextButton", lf); btn.Size = UDim2.new(0.85, 0, 0, 45); btn.Position = UDim2.new(0.075, 0, 0.65, 0); btn.Text = "ENTRAR NO HUB"; btn.Font = Enum.Font.GothamBold; btn.TextColor3 = Color3.fromRGB(10,10,10); btn.BackgroundColor3 = AccentColor; ApplyCorner(btn, 8)

    btn.MouseButton1Click:Connect(function()
        if box.Text == KEY_CORRETA then
            TweenService:Create(lf, TweenInfo.new(0.5), {Position = UDim2.new(0.5, -160, 1, 50)}):Play()
            task.wait(0.5)
            lf:Destroy()
            abrirPainel()
        else
            box.Text = ""
            box.PlaceholderText = "KEY ERRADA, DOIDÃO!"
            box.PlaceholderColor3 = Color3.new(1, 0, 0)
            task.wait(1.5)
            box.PlaceholderText = "Digite a key doidao"
            box.PlaceholderColor3 = Color3.fromRGB(178, 178, 178)
        end
    end)
end

